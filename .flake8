[flake8]
# Exclude Meta's SAM2 library (third-party code, not our responsibility)
exclude =
    sam2/,
    __pycache__,
    .git,
    .venv,
    venv,
    help/,
    test/,
    tools/,
    plugin_upload.py,
    resources.py,
    resources_rc.py

# E402: QGIS plugins require some imports after path/sys setup
# E501: long lines common in QGIS UI code (stylesheets, long strings)
# E226/E231: arithmetic/comma spacing — style preference, not a bug
# E221/E225: operator alignment — style preference
# E129: visual indentation — style preference
# W503/W504: line break style — both can't be satisfied simultaneously
ignore = E402, E501, E226, E231, E221, E225, E129, E128, E203, E701, W503, W504

# Per-file ignores
per-file-ignores =
    # resources_rc wildcard import is required by QGIS Qt resource system
    geo_osam.py: F401, F403
